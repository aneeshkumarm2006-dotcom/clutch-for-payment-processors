# --- Database ---
MONGODB_URI=mongodb://localhost:27017/paycompare

# --- Auth (NextAuth) ---
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# --- Image hosting (pick one; abstracted behind lib/upload.ts) ---
BLOB_READ_WRITE_TOKEN=
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# --- Admin seed (used by scripts/seed-admin.ts) ---
ADMIN_SEED_EMAIL=admin@paycompare.test
ADMIN_SEED_PASSWORD=change-me-in-production
# ADMIN_SEED_NAME=Admin            # optional, defaults to "Admin"

# --- Public site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Email notifications (optional; leads/submissions notify when set) ---
RESEND_API_KEY=
# From address for notifications (must be a Resend-verified domain in prod).
# EMAIL_FROM=PayCompare <onboarding@resend.dev>
# Where lead/submission notifications go (falls back to SiteSettings.contactEmail).
# LEADS_NOTIFY_EMAIL=
