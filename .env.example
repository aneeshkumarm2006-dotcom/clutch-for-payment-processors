# --- Database ---
MONGODB_URI=mongodb://localhost:27017/paycompare

# --- Auth (NextAuth) ---
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# --- SEO team dashboard (/seoteam) ---
# Single shared password the non-technical SEO team uses to sign in at /seoteam.
SEO_DASHBOARD_PASSWORD=change-me-strong-shared-password
# Secret used to sign the /seoteam session cookie (separate from NEXTAUTH_SECRET).
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-with-a-long-random-string

# --- Image hosting (pick one; abstracted behind lib/upload.ts) ---
BLOB_READ_WRITE_TOKEN=
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# --- Admin seed (used by scripts/seed-admin.ts) ---
ADMIN_SEED_EMAIL=admin@paycompare.test
ADMIN_SEED_PASSWORD=change-me-in-production
# ADMIN_SEED_NAME=Admin            # optional, defaults to "Admin"
# ADMIN_SEED_ROLE=admin            # optional [Phase 2]: 'admin' | 'editor' (or pass --role=editor)

# --- Analytics Hub (/analyticshub) ---
# ONE secret governs all hub encryption + the session cookie (HKDF-derived).
# Generate with: openssl rand -base64 32  — paste the raw 44-char output, no quotes.
# Changing it later orphans everything already stored (tokens, password). Redeploy
# after adding it — env vars only bake into deployments created afterwards.
ANALYTICSHUB_SECRET_KEY=
# Shared Google OAuth app (optional but enables "Sign in with Google" for GA4+GSC;
# without it, only the service-account path shows). One app serves all deployments.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Storage: the hub reuses MONGODB_URI above (an `analyticshub_config` collection).
# No Upstash/KV needed. Meta + Google Ads credentials are entered in the dashboard.

# --- Public site ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Email notifications (optional; leads/submissions notify when set) ---
RESEND_API_KEY=
# From address for notifications (must be a Resend-verified domain in prod).
# EMAIL_FROM=PayCompare <onboarding@resend.dev>
# Where lead/submission notifications go (falls back to SiteSettings.contactEmail).
# LEADS_NOTIFY_EMAIL=
